# Planned v1 syntax sample for non-destructive record update.
# This file documents intended syntax and is not supported by the current Rust implementation yet.

record User {
  name: String
  age: Int
}

fn birthday(self: User): User {
  self.with(age: self.age + 1)
}

user = User {
  name: "Ada"
  age: 20
}

older = user.with(age: user.age + 1)
