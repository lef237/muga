# Planned v1 syntax sample for higher-order functions and arrow function types.
# This file documents intended syntax and is not supported by the current Rust implementation yet.

fn inc(x: Int): Int {
  x + 1
}

fn apply(x: Int, f: Int -> Int): Int {
  f(x)
}

apply(10, inc)
apply(10, fn(n: Int): Int {
  n + 1
})
