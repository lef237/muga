# Planned v1 syntax sample for record / receiver-style / dot call.
# This file documents intended syntax and is not supported by the current Rust implementation yet.

record User {
  name: String
  age: Int
}

fn display_name(self: User): String {
  self.name
}

user = User {
  name: "Ada"
  age: 20
}

user.name
user.display_name()
